{
  "manifest_version": 3,
  "name": "Tab Freezer — Менеджер вкладок",
  "version": "3.0.0",
  "description": "Умная заморозка неактивных вкладок и освобождение оперативной памяти.",
  "permissions": [
    "tabs",
    "storage",
    "unlimitedStorage",
    "alarms",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Freezer"
  },
  "icons": {
    "16": "icons/snowflake-16.png",
    "48": "icons/snowflake-48.png",
    "128": "icons/snowflake-128.png"
  }
}
